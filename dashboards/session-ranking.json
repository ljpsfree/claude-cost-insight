{
  "annotations": {"list": []},
  "description": "Session 费用排行与时段分析",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "dashboard",
      "includeVars": false,
      "keepTime": true,
      "tags": [],
      "targetBlank": false,
      "title": "Overview",
      "type": "link",
      "url": "/d/claude-code-obs/claude-code-observability"
    },
    {
      "asDropdown": false,
      "icon": "search",
      "includeVars": false,
      "keepTime": true,
      "tags": [],
      "targetBlank": false,
      "title": "Session Detail",
      "type": "link",
      "url": "/d/session-detail/session-detail"
    }
  ],
  "panels": [
    {
      "title": "Session 费用排行",
      "type": "table",
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 0},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "expr": "{service_name=\"claude-code\"} | event_name=\"api_request\"",
          "legendFormat": "",
          "refId": "A"
        },
        {
          "expr": "{service_name=\"claude-code\"} | event_name=\"user_prompt\"",
          "legendFormat": "",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {"type": "auto"},
            "inspect": false,
            "filterable": true
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5},
              {"color": "red", "value": 20}
            ]
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "session_id"},
            "properties": [
              {"id": "links", "value": [{"title": "Session Detail", "url": "/d/session-detail/session-detail?var-session_id=${__value.text}&${__url_time_range}"}]}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "cost_usd (sum)"},
            "properties": [
              {"id": "displayName", "value": "Cost (USD)"},
              {"id": "unit", "value": "currencyUSD"},
              {"id": "custom.cellOptions", "value": {"type": "color-background", "mode": "gradient"}},
              {"id": "custom.width", "value": 120}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "prompt (first)"},
            "properties": [
              {"id": "displayName", "value": "First Prompt"},
              {"id": "custom.width", "value": 400}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "model (last)"},
            "properties": [
              {"id": "displayName", "value": "Model"},
              {"id": "custom.width", "value": 200}
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{"displayName": "Cost (USD)", "desc": true}]
      },
      "transformations": [
        {
          "id": "extractFields",
          "options": {"source": "labels", "format": "auto"}
        },
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "convertFieldType",
          "options": {"conversions": [
            {"targetField": "cost_usd", "destinationType": "number"},
            {"targetField": "event_sequence", "destinationType": "number"}
          ]}
        },
        {
          "id": "sortBy",
          "options": {"fields": {}, "sort": [{"field": "event_sequence", "desc": false}]}
        },
        {
          "id": "groupBy",
          "options": {
            "fields": {
              "session_id": {"aggregations": [], "operation": "groupby"},
              "cost_usd": {"aggregations": ["sum"], "operation": "aggregate"},
              "model": {"aggregations": ["last"], "operation": "aggregate"},
              "prompt": {"aggregations": ["first"], "operation": "aggregate"}
            }
          }
        },
        {
          "id": "sortBy",
          "options": {"fields": {}, "sort": [{"field": "cost_usd (sum)", "desc": true}]}
        }
      ]
    },
    {
      "title": "每日费用趋势",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(increase(claude_code_cost_usage_USD_total[$__rate_interval]))",
          "legendFormat": "Daily Cost",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "green"},
          "custom": {"drawStyle": "bars", "barAlignment": 0, "fillOpacity": 80, "gradientMode": "scheme", "stacking": {"mode": "none"}},
          "unit": "currencyUSD"
        }
      },
      "options": {"tooltip": {"mode": "single"}, "legend": {"displayMode": "hidden"}}
    },
    {
      "title": "Token 类型分布",
      "type": "piechart",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (type) (increase(claude_code_token_usage_tokens_total[$__range]))",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short"}
      },
      "options": {"legend": {"displayMode": "table", "placement": "right", "values": ["value", "percent"]}, "pieType": "donut"}
    },
    {
      "title": "按模型费用分布",
      "type": "piechart",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (model) (increase(claude_code_cost_usage_USD_total[$__range]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "currencyUSD"}
      },
      "options": {"legend": {"displayMode": "table", "placement": "right", "values": ["value", "percent"]}, "pieType": "donut"}
    },
    {
      "title": "本周 vs 上周",
      "type": "stat",
      "gridPos": {"h": 4, "w": 24, "x": 0, "y": 28},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(increase(claude_code_cost_usage_USD_total[7d]))",
          "legendFormat": "本周",
          "refId": "A"
        },
        {
          "expr": "sum(increase(claude_code_cost_usage_USD_total[7d] offset 7d))",
          "legendFormat": "上周",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto", "colorMode": "value", "graphMode": "none"}
    }
  ],
  "schemaVersion": 39,
  "tags": ["claude-code", "cost"],
  "templating": {"list": []},
  "time": {"from": "now-7d", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Claude Code - Session Ranking",
  "uid": "session-ranking"
}
